# Neon Postgres — both URLs auto-injected by the Vercel ↔ Neon marketplace
# integration. For local dev: `vercel env pull .env.local` then copy into .env.
# DATABASE_URL is the pooled connection (app queries); DATABASE_URL_UNPOOLED
# is the direct connection (Prisma migrations + introspection).
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
