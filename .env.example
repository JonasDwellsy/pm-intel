# Neon Postgres — both URLs auto-injected by the Vercel ↔ Neon marketplace
# integration. For local dev: `vercel env pull .env.local` then copy into .env.
# DATABASE_URL is the pooled connection (app queries); DATABASE_URL_UNPOOLED
# is the direct connection (Prisma migrations + introspection).
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host.neon.tech/dbname?sslmode=require"
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Research-preview access code. Middleware (middleware.ts) gates every
# request behind a /password page that validates against this value.
# Rotating it invalidates all existing dq_auth cookies because the
# SHA-256 expected digest changes. Set in .env.local for local dev,
# and in Vercel Environment Variables (Production + Preview) for deploys.
AUTH_PASSWORD="something-memorable-here"

# Anthropic API key for the Ask Dwellsy IQ natural-language interface
# (/ask + /api/ask). Powers Claude Sonnet 4.6 tool-calling against the
# 7-tool catalog in src/lib/ask-tools.ts. Required server-side only;
# never exposed to the browser. Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY="sk-ant-..."

# Clerk per-user auth (PR #50 / v0.13). Clerk is configured for email
# OTP only in the dashboard so the sign-in UX matches the existing
# Dwellsy passwordless flow. The publishable key ships to the browser;
# the secret key is server-only. Both auto-injected by the Vercel ↔
# Clerk integration; for local dev pull via `vercel env pull` or copy
# from the Clerk dashboard. Without these set the app fails closed —
# every protected route returns an error rather than letting requests
# through unauthenticated.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk webhook signing secret (PR #59 / v0.17, observability stack).
# Used by /api/clerk/webhook to verify inbound svix-signed payloads
# from Clerk's "user.created" + "session.created" events. Set this
# in the Clerk dashboard → Configure → Webhooks → endpoint, then
# paste the value here AND into Vercel env (Production + Preview).
# Without it, the webhook returns 500 and signup_completed +
# login_completed events never fire.
CLERK_WEBHOOK_SECRET="whsec_..."

# Sentry — error reporting + performance traces (PR #59 / v0.17).
# The DSN is safe to expose to the browser by design; the project
# encodes the project ID and Sentry-side rate limits gate abuse.
# SENTRY_DSN is checked first by the server runtime, falling back
# to NEXT_PUBLIC_SENTRY_DSN — set both to the same value unless you
# specifically want different error sinks for client vs server.
# SENTRY_AUTH_TOKEN + SENTRY_ORG + SENTRY_PROJECT are only needed
# at build time, for the source-map upload step in
# withSentryConfig(). Local dev builds work fine without them — the
# upload silently skips. See PRIVACY.md for what we capture.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Admin dashboard allowlist (v0.20, Stage 1.5).
# Comma-separated Clerk user IDs that can reach /admin/* routes. Get
# IDs from the Clerk dashboard (Users → click a user → "User ID"
# header). Empty/missing = nobody is admin (fail-closed). Non-admin
# signed-in users hitting /admin/* see notFound() — by design, the
# route's existence isn't advertised to non-admins.
ADMIN_USER_IDS=""

# Mapbox public token for the interactive coverage maps on operator
# scorecards (CoverageMapClient) AND the static map image embedded in
# the PDF scorecard download (PR #88). NEXT_PUBLIC_ prefix exposes it
# to the browser bundle — fine because Mapbox tokens are URL-restricted
# in the console (allowed hostnames: localhost, pm-intel-chi.vercel.app,
# iq.dwellsy.com — add new dev hosts to the Mapbox dashboard if needed).
# Without this set: maps fall back to a single-dot SVG placeholder that
# still renders cleanly but doesn't show streets/water/state borders.
# Token format: pk.eyJ... — copy from the Mapbox dashboard or from the
# Vercel project envs (it's the same value across environments).
NEXT_PUBLIC_MAPBOX_TOKEN=""
