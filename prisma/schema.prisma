// Prisma schema for the Dwellsy IQ PM Intel Platform.
// Postgres (Neon) — pooled connection for app queries, direct connection for
// migrations. Both URLs auto-injected by the Vercel ↔ Neon marketplace
// integration. Local dev pulls them via `vercel env pull .env.local`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Market {
  id                                String   @id // e.g., "chattanooga-tn"
  msaCode                           String // e.g., "16860"
  city                              String
  state                             String // 2-letter
  fullName                          String // "Chattanooga, TN-GA MSA"
  operatorCountTotal                Int
  operatorCountEligible             Int
  medianDomT12                      Float
  medianDomLifetime                 Float
  // v0.6.1 5-cell quadrant counts. JSON blob keyed by quadrant string.
  quadrantSummary                   String
  // v0.6.2 7-cell quadrant counts. JSON blob keyed by quadrant7Cell label.
  // Nullable for forward-compat with pre-v0.6.2 seeds.
  quadrant7CellSummary              String?
  // v0.6.3 — Patch 1: active operator count (≥3 listings T12) replaces the
  // legacy total-operator denominator as the surfaced headline figure.
  // activeOperatorCountBySubmarket carries per-submarket counts as a JSON
  // map (string-keyed submarket slug → int active count) for filtered-state
  // headlines. Both nullable for back-compat with pre-v0.6.3 markets.
  activeOperatorCount               Int?
  activeOperatorCountBySubmarket    String?
  // v0.6.3 — Patch 3: market-level rent growth aggregate (median YoY across
  // ranked operators), national benchmark (identical across all markets,
  // embedded per-market for render simplicity), and pre-computed pp delta
  // for the "vs national" benchmark line. All decimals (e.g. 0.0023 = +0.23%).
  marketRentGrowthT12               Float?
  nationalRentGrowthT12             Float?
  marketRentGrowthDeltaVsNationalPp Float?
  // v0.6.3 — Patch 2: eligibility-window UI label correction (T6M → T12).
  // Methodology was always T12 in production; this string is the label
  // surfaced on the headline tile + methodology page §3. Defaults to T12
  // so back-compat reseeds without an explicit value still read correctly.
  eligibilityWindow                 String?  @default("T12")
  // v0.6.4 Patch 2 — count of ranked operators in this market with at
  // least one concession-mentioning T12 listing. Drives the cohort
  // comparison line on the scorecard Layer 5 Concession Activity
  // section. Default 0 keeps the field safe for back-compat with
  // pre-Patch-2 reseeds.
  operatorsWithConcessions          Int      @default(0)
  pms                               PM[]
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt
}

model PM {
  slug                   String   @id // e.g., "doorby-property-management-chattanooga-tn"
  name                   String
  marketId               String
  market                 Market   @relation(fields: [marketId], references: [id])
  // v0.6.1 5-cell label, normalized at seed ("Scattered / Independent" etc.).
  // Kept for back-compat with existing route segments and market filters.
  quadrant               String
  // v0.6.2 7-cell canonical label ("SFR Independent", "Large MF/BTR
  // Institutional", "Hybrid", etc.). Nullable for forward-compat.
  quadrant7Cell          String?
  hybrid                 Boolean  @default(false)
  rankOverall            Int?
  rankOverallTotal       Int?
  rankQuadrant           Int?
  rankQuadrantTotal      Int?
  claimed                Boolean  @default(false)
  scorecardData          String // JSON blob: full structured scorecard
  methodologyVersion     String // e.g. "v0.6.3"
  dataAsOf               DateTime
  // v0.6.3 — Patch 1 support: per-PM T12 listing counts keyed by submarket
  // slug as a JSON map. Backs the submarket-filtered Eligible-with-footprint
  // tile (count of MSA-eligible operators with t12ListingsBySubmarket[slug]
  // > 0) without re-parsing the full scorecardData blob.
  t12ListingsBySubmarket String?
  // v0.6.3 — Patch 2 informational flag. Almost always false: the T6M→T12
  // label correction was a labeling fix, not a cohort change. Tracked so
  // future audits can attribute eligibility deltas to the correct cause.
  newlyEligibleInV063    Boolean? @default(false)
  // v0.6.4 Patch 1 — canonical operator identity. Every PM carries a
  // canonicalOperatorId; multi-market operators share the same id across
  // markets (e.g. invitation-homes across 4 markets). Single-market
  // operators get an id equal to their PM slug. canonicalOperatorName
  // is the display form (e.g. "Invitation Homes"). The canonicalOperatorId
  // is the foreign key into the CanonicalOperator table for multi-market
  // entities; single-market ids have no matching row.
  canonicalOperatorId    String?
  canonicalOperatorName  String?
  // v0.6.4 Patch 2 — concession detection results from the regex
  // classifier run against listing descriptions over the T12 window.
  // concessionRate is null when the operator wasn't found in the CSV
  // input (no T12 description data), 0 when found but no concession
  // language detected, otherwise count / t12ListingsCount as a
  // decimal. concessionPatterns is a JSON array of pattern identifiers
  // (move_in_special, free_month_lease, etc.) ordered by frequency.
  // concessionSampleText carries one representative listing excerpt
  // for display. Always non-ranking — context only on Layer 5.
  concessionListingCount Int      @default(0)
  concessionRate         Float?
  concessionPatterns     String   @default("[]") // JSON array
  concessionSampleText   String?
  // v0.6.4 Patch 2 follow-up — up to 3 distinct concession sample
  // excerpts. Authoritative for the Layer 5 UI; concessionSampleText
  // stays for back-compat with downstream readers that may not have
  // migrated yet. Stored as JSON array string, same convention as
  // concessionPatterns + the other JSON-as-String columns in the schema.
  concessionSamples      String   @default("[]")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// v0.6.4 Patch 1 — cross-market canonical operator entity.
// One row per canonical entity with marketCount ≥ 2; single-market PMs
// don't have a row here (their canonicalOperatorId equals their PM slug
// and points nowhere in this table). marketIds, pmSlugs, and
// aggregateStats are JSON-encoded strings (kept as text columns to match
// the existing JSON-as-String pattern used for scorecardData on PM and
// the quadrant summaries on Market — application code parses on read).
model CanonicalOperator {
  id             String   @id @default(cuid())
  canonicalSlug  String   @unique
  canonicalName  String
  marketIds      String // JSON array of market ids
  pmSlugs        String // JSON array of PM slugs
  marketCount    Int
  aggregateStats String // JSON blob with sum stats
  createdAt      DateTime @default(now())
}

model Lead {
  id                String   @id @default(cuid())
  marketId          String?
  propertyType      String // "single-family", "small-mf", "multifamily", "condo"
  unitCount         Int?
  preferredQuadrant String?
  ownerName         String
  ownerEmail        String
  ownerPhone        String?
  notes             String?
  matchedPms        String // JSON array of pm slugs
  source            String? // referring page
  createdAt         DateTime @default(now())
}

model Claim {
  id             String   @id @default(cuid())
  pmSlug         String
  contactEmail   String
  contactName    String
  domainVerified Boolean  @default(false)
  status         String   @default("pending") // pending | verified | rejected
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Auto-generated weekly market brief cache. One row per (marketSlug,
// methodologyVersion, dataAsOf) tuple — cache invalidates implicitly
// when either version changes because no row will exist for the new
// tuple. headlineRead, shareMovement, operatorLandscape, notableSignals
// are the four prose sections Claude produces. inputDigest is a SHA-256
// of the structured MarketBriefData input the prose was generated from,
// kept for debugging (e.g., "did the seed change but version didn't?").
model MarketBrief {
  id                 String   @id @default(cuid())
  marketSlug         String
  methodologyVersion String
  dataAsOf           DateTime
  headlineRead       String
  shareMovement      String
  operatorLandscape  String
  notableSignals     String
  inputDigest        String
  generatedAt        DateTime @default(now())

  // Composite uniqueness: at most one brief per cache key.
  @@unique([marketSlug, methodologyVersion, dataAsOf])
  @@index([marketSlug])
}

// Watch List. Acquirer-defined structured search criteria that get
// applied across the operator universe to produce a ranked target
// list. Three layers of criteria:
//   requiredCriteria  — deal-breakers. PM excluded entirely on any miss.
//   preferredCriteria — weighted preferences. Drive the 0-100 fit score.
//   excludedCriteria  — negative filters. PM excluded if any matches.
//
// Criteria are stored as JSON-encoded String columns (consistent with
// the existing JSON-as-String pattern used across this schema —
// scorecardData, marketIds, pmSlugs, aggregateStats, etc.).
// Application code parses on read; schema is provider-portable.
//
// Originally shipped in v0.8 under the model name BuyBox; renamed
// to WatchList in v0.15 via the 20260522_rename_buy_box_to_watch_list
// migration. ownerId is owned by the authenticated Clerk user as of
// PR #50.
model WatchList {
  id                String   @id @default(cuid())
  name              String
  description       String?
  ownerId           String
  isShared          Boolean  @default(true)
  // JSON-encoded arrays. See src/lib/watch-list/fields.ts for the
  // FilterCriterion + WeightedCriterion shapes.
  requiredCriteria  String   @default("[]")
  preferredCriteria String   @default("[]")
  excludedCriteria  String   @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // v0.18 (PR #65) — Multi-tenancy via Clerk Organizations.
  // organizationId is the FK that drives authorization in Phase 1+;
  // ownerId stays populated for back-compat and forensics but is no
  // longer consulted for authz checks. Nullable in Phase 1 to allow
  // the additive schema → backfill script → enforce-NOT-NULL deploy
  // sequence; a follow-up migration in the next PR enforces NOT NULL
  // once the script has run against prod data.
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  // v0.16 — per-user view ledger. Drives the change-detection
  // banner; one row written per signed-in page-view. Cascade-delete
  // so removing a watch list cleans up its view history.
  views WatchListView[]

  @@index([ownerId])
  // Hot query: list all watch lists in an org, most-recently-updated
  // first. Mirrors the existing ownerId-indexed pattern.
  @@index([organizationId, updatedAt(sort: Desc)])
}

// v0.16 — Operator change-detection feedback loop.
//
// Snapshot per (operator × dataAsOf). Written at seed time, one row
// per PM. snapshotDate carries the methodology's dataAsOf (NOT the
// deploy date) so the cadence matches the underlying data refresh
// (currently monthly: April-data lands in May, May-data lands in
// June, etc.). The @@unique([pmSlug, snapshotDate]) constraint
// makes the capture idempotent — re-deploys against the same
// scorecard JSON are no-ops via createMany({ skipDuplicates: true }).
//
// Diff comparisons read two snapshots per operator:
//   - latest        — the current state at view time
//   - prior         — the snapshot closest to (but not after) the
//                     user's last WatchListView.viewedAt
// See src/lib/watch-list/change-detection.ts for the diff logic.
//
// JSON columns follow the schema-wide JSON-as-String convention. App
// code parses on read; Postgres treats them as text.
model OperatorSnapshot {
  id                 String   @id @default(cuid())
  pmSlug             String
  snapshotDate       DateTime
  methodologyVersion String

  // Per-metric star roll-up. JSON object keyed by metric name,
  // values 'gold' | 'silver' | null. Five metrics today (leaseUp,
  // tenancy, rentPerformance, marketingDiscipline,
  // inventoryTransparency); inventoryTransparency is null for
  // SFR / Hybrid operators.
  starsPerMetric  String
  // Denormalised star totals so the banner count query doesn't have
  // to parse starsPerMetric for every operator in a watch list.
  starGoldCount   Int
  starSilverCount Int

  estimatedPortfolioPoint Int?
  // Confidence tier from the v0.7 size-banded estimator
  // ('Low' | 'Medium' | 'High') OR a non-estimated status string
  // ('insufficient_data' | 'insufficient_history' | 'no_listings').
  // Banding change is the trigger condition independent of point
  // movement, so we store the tier directly rather than re-deriving.
  estimatedPortfolioBand  String?

  // JSON array of MSA slugs the canonical operator has at least
  // one PM in at this snapshot date. For single-market operators
  // this is a 1-element array; for cross-market entities (e.g.
  // Invitation Homes across 4 markets) it's the full footprint.
  // Replicated across every PM row sharing the same
  // canonicalOperatorId so the diff can compute set delta from
  // any single PM snapshot.
  topMSAs       String
  // JSON array of submarket slugs where this PM's
  // t12ListingsBySubmarket > 0. Active-submarket footprint.
  topSubmarkets String

  concessionRate       Float?
  isEligibleForRanking Boolean
  createdAt            DateTime @default(now())

  // One snapshot per operator per data-cutoff date.
  @@unique([pmSlug, snapshotDate])
  // Latest-snapshot + closest-to-X lookups are the two hot queries.
  // DESC on snapshotDate makes "find the most recent at-or-before X"
  // a single index range scan.
  @@index([pmSlug, snapshotDate(sort: Desc)])
}

// Per-user × per-WatchList × view ledger. Written every time a
// signed-in user opens a watch list's results page. Drives the
// "since your last visit" banner — the diff compares each operator's
// latest snapshot against the snapshot closest to (but not after)
// the user's *previous* viewedAt. The current view's row gets
// written AFTER the diff is computed so the banner reflects what
// changed since last time, not since this load.
//
// v0.18 — DELIBERATELY remains per-user (not per-org). Two analysts
// in the same Organization viewing the same WatchList should have
// independent change-detection timelines, so each gets fresh signal
// on their next visit. Authorization is enforced via the parent
// WatchList's organizationId — view rows can only be read/written
// for watch lists in the caller's active org. See
// src/lib/watch-list/changes.ts for the authz wiring.
model WatchListView {
  id          String   @id @default(cuid())
  userId      String
  watchListId String
  viewedAt    DateTime @default(now())

  watchList WatchList @relation(fields: [watchListId], references: [id], onDelete: Cascade)

  // (userId, watchListId, viewedAt DESC) covers "find the prior
  // viewedAt for this user/watch-list pair" — the only hot query.
  @@index([userId, watchListId, viewedAt(sort: Desc)])
}

// v0.18 (PR #65) — Multi-tenancy Phase 1: Clerk Organizations.
//
// Mirror table for Clerk's Organization resource. We don't store
// user identity here — that stays in Clerk — but we DO mirror orgs
// + memberships so authorization queries don't have to round-trip
// through Clerk's API on every request. The mirror is kept in sync
// by webhook handlers in src/app/api/clerk/webhook/route.ts
// (organization.created/updated/deleted, organizationMembership.*).
//
// `personalForUserId` flags this row as the user's auto-provisioned
// personal workspace (one per Clerk user, created during signup).
// The @unique constraint enforces "at most one personal org per
// user" — webhook handlers + signup flow rely on this to be
// idempotent. NULL when the org was manually created (a real team
// workspace in Phase 2+).
//
// `clerkOrgId` is the @unique sync key; webhook upserts are keyed
// on it so re-delivery of the same Clerk event is a no-op.
model Organization {
  id                String   @id @default(cuid())
  clerkOrgId        String   @unique
  name              String
  slug              String?
  // Set on personal orgs (one per Clerk user, created at signup).
  // Null on team orgs (Phase 2+). The @unique constraint makes
  // "find personal org for user X" a single indexed lookup AND
  // enforces idempotency of the signup-time org provisioning.
  personalForUserId String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  memberships     OrganizationMembership[]
  watchLists      WatchList[]
  pendingWelcomes PendingWelcome[]

  // Hot lookups: "find personal org for user X" (already covered by
  // the @unique on personalForUserId) and "find org by Clerk id"
  // (covered by the @unique on clerkOrgId). No additional indexes
  // needed for Phase 1.
}

// v0.18 (PR #71, Phase 3) — Transient row marking a user as
// "should see the welcome toast next time they're active in this
// org." Written by the organizationInvitation.accepted webhook
// handler when an invitee accepts; checked + deleted inline on
// the next /watch-lists render when the user's active org matches.
//
// Design notes:
//   - One-shot semantics: present means "deliver welcome next time";
//     deleted on the first /watch-lists render that catches it.
//     The @@unique([userId, organizationId]) keeps the row idempotent
//     against duplicate webhook delivery (re-delivery is a no-op
//     upsert).
//   - Cascade-delete with Organization so removing an org cleans
//     up any orphaned pending welcomes. userId is a soft Clerk
//     reference (no FK), same convention as elsewhere in this
//     schema.
//   - Tiny table — typically empty between invitation acceptance
//     and the new user's next /watch-lists visit. No retention
//     concerns at v1 scale; if it ever grows, a cron job clearing
//     rows older than 30 days is the obvious sweep.
//
// Rationale for a dedicated table over Clerk publicMetadata: see
// PR #71's design decision section. tl;dr: avoids Clerk API rate
// limits on the write path, gives us atomic delete-on-render, and
// simplifies the cleanup story.
model PendingWelcome {
  id             String   @id @default(cuid())
  userId         String   // Clerk userId, opaque (no FK to a User table)
  organizationId String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // One pending welcome per (user × org). Webhook upserts on this
  // key, /watch-lists deletes by it.
  @@unique([userId, organizationId])
  // Hot query path: "is there a pending welcome for user X in org Y"
  // covered by the unique constraint's implicit index.
  @@index([userId])
}

// v0.18 — Mirror of Clerk's OrganizationMembership resource. Each
// row links a Clerk userId (opaque string, no FK constraint —
// users are owned by Clerk) to an Organization + role. Kept in
// sync by the organizationMembership.{created,updated,deleted}
// webhook handlers.
//
// Role values mirror Clerk's defaults: 'org:admin' | 'org:member'.
// We store the full Clerk-prefixed string so future role types
// (custom permissions in Clerk) don't require a migration.
//
// clerkMembershipId is the @unique sync key for idempotent upserts.
// (userId, organizationId) is also @unique because Clerk enforces
// "one membership per (user, org)" — duplicate webhook deliveries
// can hit either key without creating duplicates.
model OrganizationMembership {
  id                 String   @id @default(cuid())
  clerkMembershipId  String   @unique
  organizationId     String
  userId             String   // Clerk userId, opaque
  role               String   // "org:admin" | "org:member"
  createdAt          DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  // Hot query: "list all memberships for user X" (drives org
  // switcher in Phase 2 and getActiveOrgId fallback in Phase 1).
  @@index([userId])
  @@index([organizationId])
}
